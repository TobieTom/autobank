# AUTOBANK Environment Variables
# Copy this file to agents/.env and populate with real values

# ============================================
# Groq API Configuration
# ============================================
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# Ethereum / Sepolia Configuration
# ============================================
RPC_URL_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/your_alchemy_key
CHAIN_ID=11155111
USDT_CONTRACT_SEPOLIA=0xd077A400968890Eacc75cdc901F0356c943e4fDb

# ============================================
# Agent Configuration
# ============================================
PROTOCOL_FEE_PERCENT=0.5
MAX_LOAN_AMOUNT_USDT=100
MIN_REPUTATION_SCORE=40

# ============================================
# Server Configuration
# ============================================
PORT=3001
LOG_LEVEL=info
NODE_ENV=production

# ============================================
# Wallet Private Keys (TESTNET ONLY!)
# Generated by: npx ts-node src/index.ts (first run)
# NEVER commit these to git
# ============================================
LENDER_PRIVATE_KEY=0x_your_lender_private_key_64_hex_chars
BORROWER_PRIVATE_KEY=0x_your_borrower_private_key_64_hex_chars
ARBITER_PRIVATE_KEY=0x_your_arbiter_private_key_64_hex_chars

# ============================================
# Wallet Addresses
# ============================================
LENDER_ADDRESS=0xaddress_of_lender_wallet
BORROWER_ADDRESS=0xaddress_of_borrower_wallet
ARBITER_ADDRESS=0xaddress_of_arbiter_wallet

# ============================================
# Security & Deployment
# ============================================
# For Railway: set to your deployed domain
# Example: https://autobank-production.up.railway.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Secret token for /api/activate endpoint (required for production)
ACTIVATE_SECRET=your_secure_random_token_here_minimum_32_chars

# ============================================
# Frontend Configuration (Next.js)
# ============================================
# WebSocket URL for frontend to connect to agents
# Local: http://localhost:3001
# Production: https://your-railway-app.up.railway.app
NEXT_PUBLIC_WS_URL=http://localhost:3001
