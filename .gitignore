# ============================================
# AUTOBANK .gitignore - SECURITY CRITICAL
# Never commit any of the patterns below
# ============================================

# Environment variables and secrets - ABSOLUTE RULE: NEVER COMMIT
.env
.env.local
.env.development
.env.production
.env.*.local
*.pem
*.key
*.p12
*.pfx

# Private key files
*private*
*secret*
*mnemonic*
*seed*
wallet-keys.txt

# Dependencies
node_modules/
**/node_modules/

# Build outputs
dist/
.next/
out/
build/
**/dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data - wallet and reputation data stays local only
data/
**/data/*.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# TypeScript build info
*.tsbuildinfo

# IDE files
.vscode/settings.json
.idea/

# Coverage
coverage/
