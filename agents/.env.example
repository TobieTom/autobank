# ============================================
# AUTOBANK Agents — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env — it is gitignored
# ============================================

# GROQ_API_KEY: API key from console.groq.com — used for AI agent decisions
GROQ_API_KEY=your_groq_api_key_here

# RPC_URL_SEPOLIA: Alchemy (or Infura) RPC endpoint for Ethereum Sepolia testnet
RPC_URL_SEPOLIA=your_alchemy_sepolia_rpc_url_here

# CHAIN_ID: Ethereum Sepolia testnet chain ID (11155111)
CHAIN_ID=11155111

# USDT_CONTRACT_SEPOLIA: Tether USDT contract address on Sepolia
USDT_CONTRACT_SEPOLIA=0x7169D38820dfd117C3FA1f22a697dBA58d90BA06

# PROTOCOL_FEE_PERCENT: Fee taken on each loan (e.g. 0.5 = 0.5%)
PROTOCOL_FEE_PERCENT=0.5

# MAX_LOAN_AMOUNT_USDT: Maximum single loan size in USDT
MAX_LOAN_AMOUNT_USDT=100

# MIN_REPUTATION_SCORE: Minimum borrower reputation score (0-100) to qualify
MIN_REPUTATION_SCORE=40

# PORT: HTTP port the agent API server listens on
PORT=3001

# LOG_LEVEL: Logging verbosity — one of: info, warn, error
LOG_LEVEL=info

# NODE_ENV: Runtime environment — development | production
NODE_ENV=development

# Persistent wallet private keys — generated on first run, then saved here
LENDER_PRIVATE_KEY=your_lender_wallet_private_key_here
BORROWER_PRIVATE_KEY=your_borrower_wallet_private_key_here
ARBITER_PRIVATE_KEY=your_arbiter_wallet_private_key_here

# Persistent wallet addresses — corresponding public addresses
LENDER_ADDRESS=your_lender_wallet_address_here
BORROWER_ADDRESS=your_borrower_wallet_address_here
ARBITER_ADDRESS=your_arbiter_wallet_address_here
